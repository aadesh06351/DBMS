#include <stdio.h>

int main() {
    int bt[5], wt[5], n, i;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i=0;i<n;i++)
        scanf("%d",&bt[i]);

    wt[0]=0;

    for(i=1;i<n;i++)
        wt[i]=wt[i-1]+bt[i-1];

    for(i=0;i<n;i++)
        printf("P%d WT=%d\n",i+1,wt[i]);

    return 0;
}
